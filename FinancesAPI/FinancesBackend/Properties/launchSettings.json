{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "profiles": {
    "Production": {
      "commandName": "Project",
      "launchBrowser": false, // Kein Browser in Production öffnen
      "applicationUrl": "https://your-production-url.com", // Deine echte Produktions-URL
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Production" // Setze die Umgebung auf Production
      }
    }
  }
}