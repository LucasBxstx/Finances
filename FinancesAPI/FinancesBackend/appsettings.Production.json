{
  "ConnectionStrings": {
    "FinancesContext": "Server=your-db-server;Database=FinancesDB;User Id=your-user-name;Password=your-password;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "Jwt": {
    "Key": "my-production-jwt-key",
    "Issuer": "FinancesBackend",
    "Audience": "FinencesApi",
    "ExpireMinutes": 60
  },
  "AllowedHosts": "*",
  "Cors": {
    "PolicyName": "AllowSpecificOrigins",
    "Origins": "https://myfrontend.com",
    "Methods": "*",
    "Headers": "*"
  }
}
